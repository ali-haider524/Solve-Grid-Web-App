# Canonical production domain. Keep this exact domain unless you intentionally
# change every canonical URL, sitemap entry, redirect, and Search Console property.
SITE_URL=https://solvegrid.online

# Add this only after Search Console gives you a real verification token.
GOOGLE_SITE_VERIFICATION=

# Create this mailbox before publishing it. Leave blank until it works.
# Example: support@solvegrid.online
NEXT_PUBLIC_CONTACT_EMAIL=

# Optional legal operator or business name shown in policy/support updates.
NEXT_PUBLIC_SITE_OPERATOR=SolveGrid
